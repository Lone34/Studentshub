# ===========================================
# Students Hub - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# --- Database ---
# SQLite (default for local dev - leave blank to use SQLite):
# DATABASE_URL=sqlite:///chegg_bot.db
#
# PostgreSQL (for VPS/production):
# DATABASE_URL=postgresql://username:password@localhost:5432/studentshub
DATABASE_URL=sqlite:///chegg_bot.db

# --- App Secret ---
SECRET_KEY=your_secure_random_key_here

# --- AI API Keys ---
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# --- Payment: Stripe ---
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Payment: Razorpay ---
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=secret_...
RAZORPAY_WEBHOOK_SECRET=secret_...

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# --- Brevo (Email/OTP) ---
BREVO_API_KEY=your_brevo_api_key_here
